generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum fightStatus {
  WON
  LOST
  TIED
  CANCELED
}

// enum fighterStatus{
//   ACTIVE
//   RETIRED
//   INJURED
//   SUSPENDED
//   CUT
// }

enum MethodOfVictory{
  KO_TKO
  SUBMISSION
  UNANIMOUS_DECISION
  MAJORITY_DECISION
  SPLIT_DECISION
  NO_CONTEST
  DQ //disqualification
  DOCTOR_STOPPAGE
}

model User {
  id        String   @id @default(uuid())
  name          String?
  email         String?  @unique
  username      String?  @unique
  password      String?
  emailVerified DateTime?
  image         String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// verifies the identifier through a link
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Fighter{
  id                      String  @id @default(cuid())
  avgFighterStats         AvgFighterStats?

  fighterFirstName        String
  fighterLastName         String
  // fighterNationality      String
  
  fighterClass            String
  fighterSubClass         String

  fighterDOB              DateTime
  fighterHeight           Float
  fighterArmReach         Float
  fighterWeight           Float
  fighterStance           String

  // currentFighterStatus    fighterStatus //whether the fighter is active, injured or retired
  winRecord               Int
  lossRecord              Int
  tieRecord               Int

  totalElo                Int
  strikingElo             Int
  grapplingElo            Int

  fightsAsFighter1 FightResults[] @relation("fighter1")
  fightsAsFighter2 FightResults[] @relation("fighter2")
  perFightStats PerFightStats[]

}

model FightResults {
  id String @id @default(cuid())
  fighter1Id        String
  fighter2Id        String

  fighterStatus1    fightStatus
  fighterStatus2    fightStatus

  eventName         String  // event name like : UFC 322 or UFC Fight Night: Emmett vs. Vallejos
  fightBout         String  // who vs who: Josh Emmett vs. Kevin Vallejos
  fightDate         DateTime
  fightWeightClass  String
  methodOfVictory   MethodOfVictory?
  roundsLasted      Int
  roundsScheduled   Int

  fighter1 Fighter @relation("fighter1", fields: [fighter1Id], references: [id])
  fighter2 Fighter @relation("fighter2", fields: [fighter2Id], references: [id])

  perFightStats PerFightStats[]
}


model PerFightStats{
  id  String      @id @default(cuid())
  fighterId       String
  fightResultsId  String

  perStrikingStatsId    String  @unique
  perGrapplingStatsId   String  @unique

  fighter Fighter @relation(fields: [fighterId], references: [id])
  fightResult FightResults @relation(fields: [fightResultsId], references: [id])
  perStrikingStats PerStrikingStats @relation(fields: [perStrikingStatsId], references: [id], onDelete: Cascade)
  perGrapplingStats PerGrapplingStats @relation(fields: [perGrapplingStatsId], references: [id], onDelete: Cascade)

  @@unique([fighterId, fightResultsId])  
}

model PerStrikingStats{
  id String @id @default(cuid())
  perFightStats   PerFightStats?
  //avgerage offensive strikes
  kd               Int
  sigStr           Int
  sigStrPct        Float
  totalStr         Int

  // By target
  headStr          Int
  bodyStr          Int
  legStr           Int

  // By position
  distanceStr      Int
  clinchStr        Int
  groundStr        Int

  //average defensive strikes
  sigStrAbsorbedPct  Float //calculates the average amount of shots the fighter took in percentage
  sigStrAbs          Int
  headAbs            Int
  bodyAbs            Int
  legAbs             Int
  kdReceived         Int
}

model PerGrapplingStats{
  id String @id @default(cuid())
  perFightStats   PerFightStats?
  //offensive grappling
  td               Int
  tdPct            Float
  subAtt           Int
  reversals        Int
  controlTimeSec   Int
  

  //defensive
  tdAbsorbed       Int
  tdDefPct         Float  // 100 - opponent's TD% against this fighter
  subAttReceived   Int
  reversalsGiven   Int
  timeControlled   Int
}

model AvgFighterStats{
  id  String  @id @default(cuid())
  fighterId             String  @unique
  avgStrikingStatsId    String  @unique
  avgGrapplingStatsId   String  @unique

  fighter Fighter @relation(fields: [fighterId],references: [id])
  strikingStats AvgStrikingStats @relation(fields: [avgStrikingStatsId], references: [id], onDelete: Cascade)
  grapplingStats AvgGrapplingStats @relation(fields: [avgGrapplingStatsId], references: [id], onDelete: Cascade)
}



model AvgStrikingStats {
  id String @id @default(cuid())
  fighterStats AvgFighterStats?
  //avgerage offensive strikes
  avgKd               Float
  avgSigStr           Float
  avgSigStrPct        Float
  avgTotalStr         Float
  // By target
  avgHeadStr          Float
  avgBodyStr          Float
  avgLegStr           Float
  // By position
  avgDistanceStr      Float
  avgClinchStr        Float
  avgGroundStr        Float

  //average defensive strikes
  avgSigStrAbsorbedPct  Float //calculates the average amount of shots the fighter took in percentage
  avgSigStrAbs          Float 
  avgHeadAbs            Float
  avgBodyAbs            Float
  avgLegAbs             Float
  avgKdReceived         Float


}

model AvgGrapplingStats {
  id String @id @default(cuid())
  fighterStats AvgFighterStats?

  //offensive grappling
  avgTd               Float
  avgTdPct            Float
  avgSubAtt           Float
  avgReversals        Float
  avgControlTimeSec   Float
  

  //defensive
  avgTdAbsorbed       Float
  avgTdDefPct         Float  // opponent's TD% against this fighter
  avgSubAttReceived   Float
  avgReversalsGiven   Float
  avgTimeControlled   Float
}



